{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api"
    },
    {
      "source": "/toggleActivityStatus/:path*",
      "destination": "/api"
    },
    {
      "source": "/toggleschedule/:path*",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/letsquiz/frontend/dist/$1"
    }
  ]
}
