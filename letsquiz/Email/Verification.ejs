<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Message from letquiz</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            color: #000000;
            text-align: start;
        }
        .container {
            margin: 0 auto;
            padding: 20px;
            max-width: 600px;
            
            
            
            background-color: #f9f9f9;
            border: 1px solid #ddd;
            border-radius: 10px;
        }
        .header {
         
            display: flex;

        }
        .header img {
            max-width: 150px;
        }
        .heading {
            font-size: 1em;
            font-weight: bold;
            color: black;
        }
        .message {
            margin: 20px 0;
            padding: 0px 20px;
            color: black;
            width: 100%;
        }
        .button {
            background-color: #008cba;
            color: black;
            border-radius: 5px;
            text-decoration: none;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 10px 20px;
            text-align: center;
            margin: 20px 0;
        }
        .footer {
            font-size: 0.9em;
            color: #777;
        }
        .reciver-name {
            font-size: 1em;
            
        }
        .button-parent
        {
            display: flex;
            justify-content: center;
        }

    </style>
</head>
<body>
    <div class="container">
        <div class="header ">
            <img src="data:image/png;base64," alt="letquiz">
        </div>
        <div class="message">
            <h4 class="heading">New Message from LetQuiz</h4>
            <p class="receiver-name">Hi <%= userName %>,</p>
            <p>You have received a new message from <%= senderName %>.</p>
            <p>Click the button below to view and reply to the message:</p>
            <span class="button-parent">
                <a href="<%= messageLink %>" class="button">View and Reply</a>
            </span>
        </div>
        <div class="message">
            <p>To complete your registration on LetQuiz, click the button to confirm your email address.</p>
        </div>
        <div class="footer">
            <p>Please note: This is an automated email. Replies to this message will not be received. Use the button above to respond through our platform.</p>
        </div>
        
    </div>
</body>
</html>
